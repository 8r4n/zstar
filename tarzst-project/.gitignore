# ======================
# tarzst project .gitignore
# ======================

# ----- Test artifacts -----
# Generated by test/artifacts/setup_artifacts.sh and test runs
test/artifacts/tmp/
test/tmp/

# ----- Test dependencies (bats-core) -----
test/lib/

# ----- Build/run artifacts -----
# Output archives, checksums, decompression scripts, and split parts
artifacts/tmp/
*.tar.zst
*.tar.zst.gpg
*.tar.zst.sha512
*.tar.zst.*.part
*_decompress.sh

# ----- GPG temp files -----
passphrase.txt
*.asc

# ----- RPM build artifacts -----
rpmbuild/
*.rpm
*.src.rpm

# ----- SHA artifacts -----
*.sha*

# ----- OS / editor junk -----
.DS_Store
Thumbs.db
*~
*.swp
*.swo
.vscode/
.idea/
